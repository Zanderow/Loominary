# Required — Spotify
# Remove before commit
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Transcription
WHISPER_BACKEND=faster-whisper   # 'openai-whisper' or 'faster-whisper'
WHISPER_MODEL=small              # tiny/base/small/medium/large-v3
SAVE_SEGMENTS=false              # also save timestamped JSON alongside transcript

# Optional — Podcast Index (improves RSS discovery)
PODCAST_INDEX_API_KEY=
PODCAST_INDEX_API_SECRET=

# Optional — Google Drive
GOOGLE_CLIENT_SECRETS_FILE=path/to/client_secrets.json
GOOGLE_DRIVE_FOLDER_NAME=Loominary

# Paths (defaults shown)
LOOMINARY_DB_PATH=./data/loominary.duckdb
LOOMINARY_TRANSCRIPTS_DIR=./data/transcripts
LOOMINARY_TMP_DIR=./tmp

# RAG / Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=loominary_rag
EMBED_MODEL_PATH=BAAI/bge-m3        # path or HF id; baked to /models/bge-m3 in docker
EMBED_DEVICE=auto                   # auto|cpu|cuda
SPARSE_MODEL_NAME=Qdrant/bm25
RAG_CHUNK_TOKENS=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=8                         # initial hybrid candidates
RAG_CONTEXT_K=5                     # chunks injected into the prompt

# Local LLM (llama.cpp server, OpenAI-compatible)
LLM_BASE_URL=http://localhost:8080
LLM_MODEL=qwen3.5-35b-a3b
LLM_CTX_SIZE=8192                   # raise on GPU hosts
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096                    # includes reasoning + answer tokens
